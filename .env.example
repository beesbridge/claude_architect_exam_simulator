# Copy to .env.local for production-style (Supabase) runs, or set these in Vercel.
# If these are NOT set, `make server` runs in LOCAL mode (SQLite) automatically.

# Supabase project credentials (Project Settings → API)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: override the local API URL (defaults to http://localhost:8787 in dev)
# VITE_LOCAL_API=http://localhost:8787
